NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_ID=contract_agent

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_SESSION_SECRET=

# Azure B2C / Entra External ID
AZURE_B2C_TENANT_NAME=
AZURE_B2C_POLICY=
AZURE_B2C_CLIENT_ID=
AZURE_B2C_CLIENT_SECRET=
AZURE_B2C_REDIRECT_URI=
AZURE_B2C_SCOPES=openid profile email

# Supabase Auth (optional - Google/Apple OAuth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# Azure Cosmos DB
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=contract_agent

# ─── AI Providers (fallback chain: Foundry → Azure OpenAI → DeepSeek → Ollama → Gemini)
# 1. Azure AI Foundry (primary - fastest, best quality)
#    Endpoint: https://<project>.services.ai.azure.com/models
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_DEPLOYMENT=gpt-4o

# 2. Azure OpenAI (legacy resource - optional secondary)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# 3. DeepSeek v3 (cost-efficient, OpenAI-compatible)
#    Get key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# 4. Ollama (self-hosted fast backup - run locally or on a server)
#    Default: http://localhost:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# 5. Google Gemini (final fallback)
GEMINI_API_KEY=
